{
  "@context": "https://www.w3.org/ns/solid/oidc-context.jsonld",
  "client_id": "https://kevinzzzhu.github.io/solid-app-pages/client-profile.jsonld",
  "client_name": "NotepodApp",
  "application_type": "native",
  "redirect_uris": [
    "https://kevinzzzhu.github.io/solid-app-pages/redirect.html",
    "com.example.notepodapp://redirect",
    "http://localhost:4400/redirect"
  ],
  "post_logout_redirect_uris": [
    "https://kevinzzzhu.github.io/solid-app-pages/redirect.html",
